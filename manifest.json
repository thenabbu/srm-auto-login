{
  "manifest_version": 3,
  "name": "SRM Auto Login",
  "version": "1.3.0",
  "description": "Automatically logs into SRM Google account",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://accounts.google.com/*"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_scripts": [
    {
      "matches": ["https://accounts.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "SRM Auto Login",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "srm-auto-login@thenabbu.github.io",
      "strict_min_version": "109.0"
    }
  }
}
